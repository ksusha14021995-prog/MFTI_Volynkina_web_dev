            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users?is_active=true&page=1&limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users"],
              "query": [
                { "key": "is_active", "value": "true", "description": "true | false (по умолчанию — все)" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "50" }
              ]
            },
            "description": "Листинг всех админов с фильтром по активности."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
