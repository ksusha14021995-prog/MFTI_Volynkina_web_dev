              "header": [{ "key": "Content-Type", "value": "application/json; charset=utf-8" }],
              "body": "{\n  \"error\": {\n    \"code\": \"ACCOUNT_DEACTIVATED\",\n    \"message\": \"Учётная запись администратора деактивирована\"\n  }\n}"
