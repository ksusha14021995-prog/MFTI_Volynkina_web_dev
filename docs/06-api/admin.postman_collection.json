              "body": "{\n  \"error\": {\n    \"code\": \"INVALID_CREDENTIALS\",\n    \"message\": \"Неверный email или пароль\"\n  }\n}"
            },
            {
              "name": "403 Forbidden — учётка деактивирована",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": {
                  "raw": "{{base_url}}/api/admin/auth/login",
