        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/admin/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "auth", "logout"]
            },
            "description": "Инвалидирует текущий JWT (добавляет jti в чёрный список до конца срока действия)."
          },
          "response": [
            {
              "name": "204 No Content",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": {
