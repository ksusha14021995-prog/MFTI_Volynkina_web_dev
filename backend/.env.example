# Скопировать в .env и подставить реальные значения. .env в git не коммитится.

# catalog-service / catalog-db
CATALOG_POSTGRES_USER=catalog
CATALOG_POSTGRES_PASSWORD=catalog_pw_change_me
CATALOG_POSTGRES_DB=catalog

# orders-service / orders-db
ORDERS_POSTGRES_USER=orders
ORDERS_POSTGRES_PASSWORD=orders_pw_change_me
ORDERS_POSTGRES_DB=orders

# orders → catalog (внутренний URL в сети docker-compose)
CATALOG_SERVICE_URL=http://catalog-service:8000
